{
  "name": "enclav",
  "version": "1.0.0",
  "main": "electron/main.js",
  "description": "Enclav - zero-CLI AI agent installer",
  "author": "",
  "license": "ISC",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "start": "npm run build && electron .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [
    "electron",
    "react",
    "vite",
    "ai",
    "agents"
  ],
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.example.app",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable"
    }
  }
}